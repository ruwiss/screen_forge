<Window x:Class="ScreenForge.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenForge Hakkında" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#11141B" Foreground="{StaticResource TextBrush}"
        FontFamily="{StaticResource UiFont}">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </Window.Resources>

    <StackPanel Margin="14">
        <TextBlock Text="Hakkında" Style="{StaticResource Heading}" Margin="2,0,0,12" />

        <Border Style="{StaticResource Card}">
            <DockPanel>
                <Image Source="pack://application:,,,/Resources/app.png" Width="56" Height="56"
                       VerticalAlignment="Top" Margin="0,4,14,0" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ScreenForge" Style="{StaticResource Heading}" FontSize="22" Margin="0,0,0,2" />
                    <TextBlock Text="Sürüm 1.0.3" Style="{StaticResource Muted}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Style="{StaticResource Card}">
            <TextBlock Style="{StaticResource Label}" TextWrapping="Wrap"
                       Text="Modern, hızlı bir ekran alıntı ve düzenleme aracı. Lightshot alternatifi; gelişmiş çizim araçları, adım işaretleri, bulanıklaştırma, kolaj modu ve buluta yükleme içerir." />
        </Border>

        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource Muted}" Text="Tasarım dili: Windows 11" />
                <TextBlock Style="{StaticResource Muted}" Text="Dil: Türkçe" Margin="0,2,0,0" />
                <TextBlock Style="{StaticResource Muted}" Text=".NET 9 · WPF · SkiaSharp" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}">
            <DockPanel>
                <TextBlock Style="{StaticResource Label}" Text="Geliştirici" VerticalAlignment="Center" />
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Hyperlink x:Name="LnkGitHub" Foreground="{StaticResource AccentBrush}" TextDecorations="None">
                        github.com/ruwiss
                    </Hyperlink>
                </TextBlock>
            </DockPanel>
        </Border>

        <Button x:Name="BtnOk" Content="Kapat" Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Right" Width="100" Margin="0,2,0,0" />
    </StackPanel>
</Window>
