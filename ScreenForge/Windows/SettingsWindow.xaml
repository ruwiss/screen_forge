<Window x:Class="ScreenForge.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenForge Ayarları" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#11141B" Foreground="{StaticResource TextBrush}"
        FontFamily="{StaticResource UiFont}">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock" BasedOn="{StaticResource Muted}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style TargetType="CheckBox" BasedOn="{StaticResource ToggleCheck}">
            <Setter Property="Margin" Value="0,4" />
        </Style>
    </Window.Resources>

    <StackPanel Margin="14">
        <TextBlock Text="Ayarlar" Style="{StaticResource Heading}" Margin="2,0,0,12" />

        <TabControl x:Name="TabCtrl" Style="{StaticResource SettingsTab}">
            <!-- ===== Genel ===== -->
            <TabItem Header="Genel" Style="{StaticResource SettingsTabItem}">
                <StackPanel>
                    <!-- Yakalama -->
                    <TextBlock Text="Yakalama" Style="{StaticResource SectionTitle}" />
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <CheckBox x:Name="ChkShowCursor" Content="Fare imlecini göster" />
                        </StackPanel>
                    </Border>

                    <!-- Yükleme -->
                    <TextBlock Text="Yükleme" Style="{StaticResource SectionTitle}" />
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <CheckBox x:Name="ChkAutoCopy" Content="Bağlantıyı otomatik kopyala" />
                            <CheckBox x:Name="ChkAutoClose" Content="Pencereyi otomatik kapat" Margin="28,4,0,4" />
                        </StackPanel>
                    </Border>

                    <!-- Sistem -->
                    <TextBlock Text="Sistem" Style="{StaticResource SectionTitle}" />
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <CheckBox x:Name="ChkStartup" Content="Windows ile birlikte başlat" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- ===== Kısayollar ===== -->
            <TabItem Header="Kısayollar" Style="{StaticResource SettingsTabItem}">
                <StackPanel x:Name="HotkeyPanel" />
            </TabItem>

            <!-- ===== Çıktı ===== -->
            <TabItem Header="Çıktı" Style="{StaticResource SettingsTabItem}">
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <DockPanel Margin="0,2">
                            <TextBlock Style="{StaticResource Label}" Text="Dosya türü" Width="110" VerticalAlignment="Center" />
                            <ComboBox x:Name="CmbFormat" Width="120" HorizontalAlignment="Left">
                                <ComboBoxItem Content="PNG" />
                                <ComboBoxItem Content="JPEG" />
                                <ComboBoxItem Content="WebP" />
                            </ComboBox>
                        </DockPanel>
                        <TextBlock Style="{StaticResource Muted}" FontSize="11" Margin="0,4,0,0"
                                   Text="Saydam arkaplan seçilirse çıktı her zaman PNG olarak kaydedilir." />

                        <StackPanel x:Name="QualityPanel" Margin="0,8,0,0">
                            <DockPanel>
                                <TextBlock Style="{StaticResource Label}" Width="110" VerticalAlignment="Center">
                                    <Run Text="Kalite: " /><Run x:Name="QualityValue" Text="92" />
                                </TextBlock>
                                <Slider x:Name="SldQuality" Minimum="1" Maximum="100" Value="92" VerticalAlignment="Center" />
                            </DockPanel>
                        </StackPanel>

                        <TextBlock Style="{StaticResource Label}" Text="Kayıt klasörü" Margin="0,10,0,4" />
                        <DockPanel>
                            <Button DockPanel.Dock="Right" x:Name="BtnBrowse" Content="Gözat…" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Padding="10,5" />
                            <TextBox x:Name="TxtSaveDir" IsReadOnly="True" Padding="6,5" VerticalContentAlignment="Center" />
                        </DockPanel>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <Button x:Name="BtnClose" Content="Kapat" Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Right" Width="100" Margin="0,2,0,0" />
    </StackPanel>
</Window>
