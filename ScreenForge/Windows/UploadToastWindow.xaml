<Window x:Class="ScreenForge.Windows.UploadToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenForge" Width="370" SizeToContent="Height"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False" Topmost="True"
        Opacity="0">
    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="14,12"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="4" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Icon circle -->
            <Border x:Name="IconBorder" Grid.RowSpan="2" Width="38" Height="38" CornerRadius="19"
                    Background="{StaticResource AccentBrush}" Margin="0,0,12,0" VerticalAlignment="Top">
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Viewbox x:Name="CloudIcon" Width="18" Height="18">
                        <Path Data="{StaticResource IconCloud}" Stroke="White" StrokeThickness="2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Fill="Transparent" Width="24" Height="24" Stretch="Uniform"/>
                    </Viewbox>
                    <Viewbox x:Name="CheckIcon" Width="18" Height="18" Visibility="Collapsed">
                        <Path Data="M20 6 L9 17 L4 12" Stroke="White" StrokeThickness="2.5"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Fill="Transparent" Width="24" Height="24" Stretch="Uniform"/>
                    </Viewbox>
                </Grid>
            </Border>

            <!-- Title + percent -->
            <DockPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="PercentText" DockPanel.Dock="Right" Text="%0"
                           Foreground="{StaticResource AccentBrush}"
                           FontFamily="{StaticResource UiFont}" FontSize="13" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                <TextBlock x:Name="TitleText" Text="Buluta yükleniyor…"
                           Style="{StaticResource Label}" FontWeight="SemiBold"/>
            </DockPanel>

            <!-- Close button (SVG icon) -->
            <Button x:Name="BtnClose" Grid.Column="2" Grid.RowSpan="2" VerticalAlignment="Top"
                    Width="24" Height="24" Cursor="Hand" Margin="6,0,0,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="4"
                                Width="24" Height="24">
                            <Viewbox Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconClose}"
                                      Stroke="{StaticResource TextMutedBrush}" StrokeThickness="2.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Width="24" Height="24" Stretch="Uniform"/>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Progress bar (upload phase) -->
            <Border x:Name="ProgressTrack" Grid.Row="1" Grid.Column="1" Height="4" CornerRadius="2"
                    Background="{StaticResource SurfaceAltBrush}" Margin="0,8,0,2" ClipToBounds="True">
                <Border x:Name="ProgressFill" Background="{StaticResource AccentBrush}"
                        RenderTransformOrigin="0,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="ProgressScale" ScaleX="0"/>
                    </Border.RenderTransform>
                </Border>
            </Border>

            <!-- Result row (success phase) -->
            <DockPanel x:Name="ResultPanel" Grid.Row="1" Grid.Column="1"
                       Margin="0,6,0,0" Visibility="Collapsed">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                    <Button x:Name="BtnCopyLink" Content="Kopyala"
                            Style="{StaticResource SecondaryButton}" Padding="10,4" FontSize="12"/>
                    <Button x:Name="BtnOpen" Content="Aç"
                            Style="{StaticResource PrimaryButton}" Padding="10,4"
                            Margin="6,0,0,0" FontSize="12"/>
                </StackPanel>
                <TextBlock x:Name="LinkText" Style="{StaticResource Muted}"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
            </DockPanel>
        </Grid>
    </Border>
</Window>
