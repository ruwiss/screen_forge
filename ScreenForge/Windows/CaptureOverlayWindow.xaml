<Window x:Class="ScreenForge.Windows.CaptureOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenForge" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="False" Background="Black" ShowInTaskbar="False"
        Topmost="True" WindowStartupLocation="Manual"
        UseLayoutRounding="True"
        Cursor="Cross">
    <Canvas x:Name="Root" ClipToBounds="True">
        <!-- Yakalanan ekran (arka plan): selection sırasında LowQuality yeterli -->
        <Image x:Name="ScreenImage" Stretch="Fill"
               RenderOptions.BitmapScalingMode="LowQuality" />

        <!-- Karartma — 4 dikdörtgen (CombinedGeometry yerine performanslı) -->
        <Rectangle x:Name="DimTop"    Fill="#7A000000" />
        <Rectangle x:Name="DimBottom" Fill="#7A000000" />
        <Rectangle x:Name="DimLeft"   Fill="#7A000000" />
        <Rectangle x:Name="DimRight"  Fill="#7A000000" />

        <!-- Düzenleme tuvali (Faz 2'de InteractiveCanvas eklenir) -->
        <Border x:Name="EditHost" Visibility="Collapsed" />

        <!-- Seçim çerçevesi — kesik çizgi (EditHost üzerinde görünmesi için sonra) -->
        <Rectangle x:Name="SelectionBorder" Stroke="White" StrokeThickness="1.5"
                   StrokeDashArray="6 4" StrokeDashCap="Round"
                   Visibility="Collapsed" IsHitTestVisible="False" />

        <!-- Pencere algılama çerçevesi — hover sırasında aktif pencereyi gösterir -->
        <Rectangle x:Name="WinHoverBorder"
                   Stroke="#FFAA33" StrokeThickness="2"
                   StrokeDashArray="5 3" StrokeDashCap="Round"
                   Visibility="Collapsed" IsHitTestVisible="False" />

        <!-- Boyut etiketi -->
        <Border x:Name="SizeBadge" Background="#CC1F2430" CornerRadius="4" Padding="8,3"
                Visibility="Collapsed" IsHitTestVisible="False">
            <TextBlock x:Name="SizeText" Foreground="White" FontFamily="Segoe UI" FontSize="12" />
        </Border>

        <!-- Üst-orta mod çubuğu (yalnızca seçim öncesi) -->
        <Border x:Name="ModeBar" Background="#F21F2430" CornerRadius="6" Padding="3"
                BorderBrush="#3A4254" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="2" Opacity="0.45" />
            </Border.Effect>
            <StackPanel x:Name="ModeStack" Orientation="Horizontal" />
        </Border>

        <!-- Üst-orta aksiyon çubuğu (düzenleme fazında; Kopyala/Kaydet/Yükle) -->
        <Border x:Name="ActionBar" Visibility="Collapsed"
                Background="#F21F2430" CornerRadius="6" Padding="3"
                BorderBrush="#3A4254" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="2" Opacity="0.45" />
            </Border.Effect>
            <StackPanel x:Name="ActionStack" Orientation="Horizontal" />
        </Border>

        <!-- Dikey araç şeridi (Faz 2) -->
        <Border x:Name="Toolbar" Visibility="Collapsed"
                Background="#F21F2430" CornerRadius="6" Padding="0"
                BorderBrush="#3A4254" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="2" Opacity="0.45" />
            </Border.Effect>
            <DockPanel>
                <Border x:Name="ToolbarGrip" DockPanel.Dock="Left" Width="10" Cursor="SizeAll"
                        Background="Transparent" Margin="0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Ellipse Width="3" Height="3" Fill="#60FFFFFF" Margin="0,1.5"/>
                        <Ellipse Width="3" Height="3" Fill="#60FFFFFF" Margin="0,1.5"/>
                        <Ellipse Width="3" Height="3" Fill="#60FFFFFF" Margin="0,1.5"/>
                    </StackPanel>
                </Border>
                <StackPanel x:Name="ToolStack" Orientation="Vertical" Margin="2" />
            </DockPanel>
        </Border>

        <!-- Serbest mod boş sahne placeholder -->
        <StackPanel x:Name="PlaceholderPanel" Visibility="Collapsed" IsHitTestVisible="False" Opacity="0.2">
            <Path Data="M19,3H5A2,2,0,0,0,3,5V19a2,2,0,0,0,2,2H19a2,2,0,0,0,2-2V5A2,2,0,0,0,19,3ZM9,11.5A1.5,1.5,0,1,1,10.5,10,1.5,1.5,0,0,1,9,11.5ZM19,19H5L9,13l2,3,3-4Z"
                  Fill="White" Stretch="Uniform" Width="64" Height="64" HorizontalAlignment="Center" />
            <TextBlock Text="Buraya resim yapıştırabilirsiniz" Foreground="White" FontSize="16"
                       FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,12,0,0" />
            <TextBlock Text="Ctrl+V" Foreground="#80FFFFFF" FontSize="13"
                       FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Yatay seçenek şeridi (Faz 2, seçimin altında) -->
        <Border x:Name="OptionBar" Visibility="Collapsed"
                Background="#F21F2430" CornerRadius="6" Padding="5,4"
                BorderBrush="#3A4254" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="2" Opacity="0.45" />
            </Border.Effect>
            <StackPanel x:Name="OptionStack" Orientation="Horizontal" VerticalAlignment="Center" />
        </Border>

        <!-- İpucu (Faz 1) -->
        <Border x:Name="HintBox" Background="#CC1F2430" CornerRadius="6" Padding="14,8"
                IsHitTestVisible="False">
            <TextBlock x:Name="HintText" Foreground="#D0D6E2" FontFamily="Segoe UI" FontSize="13"
                       Text="Alan seçmek için sürükleyin" />
        </Border>

        <!-- Sağ üst hover etiket -->
        <Border x:Name="HoverLabel" Visibility="Collapsed" IsHitTestVisible="False"
                Background="#CC1F2430" CornerRadius="4" Padding="7,3">
            <TextBlock x:Name="HoverText" Foreground="#9AA4B8" FontFamily="Segoe UI" FontSize="11"/>
        </Border>
    </Canvas>
</Window>
